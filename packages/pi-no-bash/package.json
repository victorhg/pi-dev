{
  "name": "@victorhg/pi-no-bash",
  "version": "0.1.0",
  "description": "Production security extension — permanently removes bash tool access from the Pi agent to eliminate shell execution as an attack vector.",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "keywords": [
    "pi-package"
  ],
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "tsc",
    "build:self": "tsc",
    "check:self": "tsc --noEmit"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "file:../../../../../../opt/homebrew/lib/node_modules/@earendil-works/pi-coding-agent",
    "typescript": "^5.0.0"
  }
}
