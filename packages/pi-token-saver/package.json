{
  "name": "@victorhg/pi-token-saver",
  "version": "0.1.0",
  "description": "Intelligent bash output filtering to reduce token consumption",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./pi-hook": "./dist/pi-hook.js"
  },
  "keywords": [
    "pi-package"
  ],
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "pi": {
    "extensions": [
      "./dist/pi-hook.js"
    ]
  },
  "scripts": {
    "build": "tsc",
    "build:self": "tsc",
    "check:self": "tsc --noEmit",
    "test:self": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.6"
  },
  "optionalDependencies": {
    "@victorhg/pi-footer": "workspace:*"
  }
}
