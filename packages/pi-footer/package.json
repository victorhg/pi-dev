{
  "name": "@victorhg/pi-footer",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./registry": {
      "types": "./dist/registry/index.d.ts",
      "default": "./dist/registry/index.js"
    }
  },
  "keywords": [
    "pi-package"
  ],
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "tsc",
    "build:self": "tsc",
    "check:self": "tsc --noEmit",
    "test:self": "vitest run"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.1.0",
    "@earendil-works/pi-tui": ">=0.1.0"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "file:../../../../../../opt/homebrew/lib/node_modules/@earendil-works/pi-coding-agent",
    "@earendil-works/pi-tui": "file:../../node_modules/.pnpm/@earendil-works+pi-tui@0.80.10/node_modules/@earendil-works/pi-tui",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
