  "description": "Obsidian vault tools for the Pi coding agent — read, search, create, and manage notes via the Obsidian CLI.",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "keywords": [
