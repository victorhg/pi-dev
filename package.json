{
	"private": true,
	"scripts": {
		"build": "pnpm -r build",
		"check": "pnpm -r --if-present run check:self",
		"test": "pnpm -r --if-present run test:self",
		"check:skills": "pnpx check-skills validate .agents skills --recursive",
		"validate": "pnpm run build && pnpm run check && pnpm run test && pnpm run check:skills"
	},
	"dependencies": {
		"@victorhg/pi-themes": "workspace:*",
		"@victorhg/pi-footer": "workspace:*",
		"@victorhg/pi-research": "workspace:*",
		"@victorhg/pi-token-saver": "workspace:*",
		"@victorhg/pi-auto-compact": "workspace:*"
	}
}
